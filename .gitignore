# ==========================================
# dispatcherZ 独自の除外設定（重要！）
# ==========================================
# 古いソースコードのバックアップを除外
lib-bak/

# アプリ内で保存したローカルのレイアウトプロファイルを除外
dispatcherz_layout_*.json
dispatcherz_last_profile.txt

# ダッシュボードからエクスポートした個人情報を含むCSVを除外
dispatcherz_export_*.csv

# Pythonの着信モジュールの一時ファイルを除外
/tmp/dispatcherz_incoming.txt
__pycache__/